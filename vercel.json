{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm --filter @workspace/neurohacking run build",
  "outputDirectory": "artifacts/neurohacking/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/sounds/:path*",
      "destination": "/sounds/:path*"
    },
    {
      "source": "/sounds/:path*/",
      "destination": "/sounds/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
